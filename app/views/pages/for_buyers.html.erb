<section class="hero">
  <div class="container">
    <h1 class="hero__title">For International Buyers</h1>
    <p class="hero__subtitle">
      Source from verified Indian manufacturers. Use AI to discover suppliers, compare options, and connect directly with exporters.
    </p>
    <%= link_to "Sign up as buyer", signup_path, class: "btn btn--primary btn--lg" %>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <h2 class="section__title">How it works</h2>
    <p class="section__subtitle">Four steps to smarter sourcing from India.</p>
    <div class="steps">
      <div class="step">
        <span class="step__num">1</span>
        <div>
          <h3 class="step__title">Search suppliers</h3>
          <p class="step__text">Use the marketplace and AI tools to find manufacturers by product, industry, location, and certifications.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">2</span>
        <div>
          <h3 class="step__title">Compare manufacturers</h3>
          <p class="step__text">View MOQ, export markets, and verification status. Shortlist suppliers that match your requirements.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">3</span>
        <div>
          <h3 class="step__title">Analyze demand using AI</h3>
          <p class="step__text">Use our demand and market tools to validate product opportunity and plan volumes before reaching out.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">4</span>
        <div>
          <h3 class="step__title">Connect directly with exporters</h3>
          <p class="step__text">Message and negotiate with verified Indian exporters. No middlemen—direct B2B relationships.</p>
        </div>
      </div>
    </div>
    <p class="text-center" style="margin-top: 2rem;">
      <%= link_to "Create free account", signup_path, class: "btn btn--primary btn--lg" %>
    </p>
    <p class="text-center" style="margin-top: 1.5rem; font-size: 0.9375rem; color: var(--color-text-muted);">
      Questions? Email us at <a href="mailto:team@amaraindia.com">team@amaraindia.com</a>
    </p>
  </div>
</section>
