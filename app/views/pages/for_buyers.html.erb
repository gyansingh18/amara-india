<section class="hero">
  <div class="container">
    <h1 class="hero__title">For global buyers</h1>
    <p class="hero__subtitle">
      Source gym equipment, sports gear, and fitness products from verified Indian manufacturers. Direct factory access, transparent MOQs, and export-ready suppliers.
    </p>
    <%= link_to "Find manufacturers", products_path, class: "btn btn--primary btn--lg" %>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <h2 class="section__title">How it works</h2>
    <p class="section__subtitle">Four steps to sourcing sports and fitness products from India.</p>
    <div class="steps">
      <div class="step">
        <span class="step__num">1</span>
        <div>
          <h3 class="step__title">Search manufacturers</h3>
          <p class="step__text">Browse by category—gym equipment, cricket gear, yoga, training equipment, fitness accessories. Filter by location, certifications, and MOQ.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">2</span>
        <div>
          <h3 class="step__title">Compare supplier profiles</h3>
          <p class="step__text">View factory location, products offered, MOQ, export countries, certifications, and production capacity. Shortlist manufacturers that fit your requirements.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">3</span>
        <div>
          <h3 class="step__title">Request a quote</h3>
          <p class="step__text">Connect directly with manufacturers. No middlemen—negotiate and order with export-ready Indian factories.</p>
        </div>
      </div>
      <div class="step">
        <span class="step__num">4</span>
        <div>
          <h3 class="step__title">Scale your brand</h3>
          <p class="step__text">Use private label, flexible MOQs, and transparent pricing to grow. Future AI tools will help you benchmark and discover opportunities.</p>
        </div>
      </div>
    </div>
    <p class="text-center" style="margin-top: 2rem;">
      <%= link_to "Browse manufacturers", products_path, class: "btn btn--primary btn--lg" %>
    </p>
    <p class="text-center" style="margin-top: 1.5rem; font-size: 0.9375rem; color: var(--color-text-muted);">
      Questions? <a href="mailto:team@amaraindia.com">team@amaraindia.com</a>
    </p>
  </div>
</section>
