<section class="hero">
  <div class="container">
    <h1 class="hero__title">For Indian Suppliers</h1>
    <p class="hero__subtitle">
      Reach global buyers, get AI-powered market insights, and grow your export business with Amara India.
    </p>
    <%= link_to "Get started", signup_path, class: "btn btn--primary btn--lg" %>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <h2 class="section__title">Why join Amara India</h2>
    <p class="section__subtitle">Built for Indian manufacturers and exporters.</p>
    <ul class="benefits-list">
      <li><strong>Get global buyers</strong> — Your profile is visible to international importers searching for Indian suppliers.</li>
      <li><strong>AI market insights</strong> — See demand trends and product opportunities to align production and exports.</li>
      <li><strong>Export growth tools</strong> — Use intelligence on markets, tariffs, and demand to plan expansion.</li>
      <li><strong>Global visibility</strong> — Verified badge and structured listing help you stand out in search and filters.</li>
    </ul>
    <p class="text-center" style="margin-top: 2rem;">
      <%= link_to "Create free account", signup_path, class: "btn btn--primary btn--lg" %>
    </p>
    <p class="text-center" style="margin-top: 1.5rem; font-size: 0.9375rem; color: var(--color-text-muted);">
      Questions? <a href="mailto:team@amaraindia.com">team@amaraindia.com</a>
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section__title">Supplier onboarding</h2>
    <p class="section__subtitle">Register your company to get verified and start receiving buyer inquiries.</p>
    <div class="onboarding-form">
      <form action="#" method="post">
        <div class="form-group">
          <label for="company">Company name</label>
          <input type="text" id="company" name="company" required placeholder="Your company name">
        </div>
        <div class="form-group">
          <label for="email">Business email</label>
          <input type="email" id="email" name="email" required placeholder="you@company.com">
        </div>
        <div class="form-group">
          <label for="industry">Primary industry</label>
          <select id="industry" name="industry">
            <option value="">Select industry</option>
            <option value="agriculture">Agriculture</option>
            <option value="textiles">Textiles</option>
            <option value="electronics">Electronics</option>
            <option value="machinery">Machinery</option>
            <option value="handicrafts">Handicrafts</option>
            <option value="industrial">Industrial Goods</option>
            <option value="food">Food Products</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Tell us about your products (optional)</label>
          <textarea id="message" name="message" rows="4" placeholder="Main products, export experience, certifications..."></textarea>
        </div>
        <button type="submit" class="btn btn--primary btn--lg" style="width: 100%;">Submit</button>
      </form>
    </div>
  </div>
</section>
