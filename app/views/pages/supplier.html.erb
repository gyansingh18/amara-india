<section class="section">
  <div class="container container--narrow">
    <%= link_to "← Back to manufacturers", products_path, class: "nav__link", style: "margin-bottom: 1rem; display: inline-block;" %>

    <div class="supplier-profile">
      <div class="supplier-profile__header">
        <div class="supplier-profile__logo">Logo</div>
        <div>
          <h1 class="supplier-profile__name">Premium Gym Equipment Co.</h1>
          <p class="supplier-profile__location">Ludhiana, Punjab, India</p>
          <span class="supplier-profile__badge">Verified</span>
        </div>
      </div>

      <div class="supplier-profile__grid">
        <div class="supplier-profile__block">
          <h3>Products offered</h3>
          <p>Treadmills, ellipticals, weight equipment, multi-gym stations, benches, racks. Private label and OEM supported.</p>
        </div>
        <div class="supplier-profile__block">
          <h3>MOQ</h3>
          <p>100 units per SKU (negotiable for larger orders).</p>
        </div>
        <div class="supplier-profile__block">
          <h3>Export countries</h3>
          <p>United States, United Kingdom, UAE, European Union, Australia.</p>
        </div>
        <div class="supplier-profile__block">
          <h3>Certifications</h3>
          <p>ISO 9001:2015, CE marked products. Quality and safety compliant for major markets.</p>
        </div>
        <div class="supplier-profile__block">
          <h3>Production capacity</h3>
          <p>10,000+ units per month. In-house R&D and customization available.</p>
        </div>
      </div>

      <div class="supplier-profile__cta">
        <p>Request a quote or connect directly with this manufacturer.</p>
        <a href="mailto:team@amaraindia.com?subject=Quote%20request%20-%20Premium%20Gym%20Equipment%20Co." class="btn btn--primary btn--lg">Request quote</a>
      </div>
    </div>
  </div>
</section>
